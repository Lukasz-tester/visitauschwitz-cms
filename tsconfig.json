{
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "target": "es6",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "sourceMap": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@payload-config": [
        "./src/payload.config.ts"
      ],
      "react": [
        "./node_modules/@types/react"
      ],
      "@/*": [
        "./src/*"
      ],
      "@payload-enchants/translator": ["./src/lib/translator/dist/index"],
      "@payload-enchants/translator/client": ["./src/lib/translator/dist/exports/client"],
      "@payload-enchants/translator/types": ["./src/lib/translator/dist/types"],
      "@payload-enchants/translator/resolvers/openAI": ["./src/lib/translator/dist/resolvers/openAI"],
      "@payload-enchants/translator/resolvers/google": ["./src/lib/translator/dist/resolvers/google"],
      "@payload-enchants/translator/resolvers/copy": ["./src/lib/translator/dist/resolvers/copy"],
      "@payload-enchants/translator/resolvers/types": ["./src/lib/translator/dist/resolvers/types"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "redirects.js",
    "next.config.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
