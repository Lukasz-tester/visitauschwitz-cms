+/**
+ * Recursively finds array fields whose items contain a block-type union
+ * (anyOf/oneOf with members having a blockType property) and replaces the
+ * items schema with {} (accept any) to avoid json-schema-to-zod failing
+ * on discriminated unions.
+ */ function stripBlockUnions(obj) {
+    if (!obj || typeof obj !== 'object') return obj;
+    // Check if this is an array field with block-type union items
+    if (obj.type === 'array' && obj.items) {
+        const members = obj.items.oneOf || obj.items.anyOf;
+        if (Array.isArray(members) && members.length > 0 && members.every(
+            (m) => m?.$ref || m?.properties?.blockType || m?.properties?.blockName
+        )) {
+            obj.items = {};
+            return obj;
+        }
+    }
+    // Recurse into properties
+    if (obj.properties) {
+        for (const value of Object.values(obj.properties)) {
+            stripBlockUnions(value);
+        }
+    }
+    // Recurse into items (for non-block arrays with nested objects)
+    if (obj.items && typeof obj.items === 'object') {
+        stripBlockUnions(obj.items);
+    }
+    return obj;
+}
